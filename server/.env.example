# ============================================
# ARK NEET Launchpad — Server Environment
# Copy to .env and fill in real values
# ============================================

# Server
PORT=4000
NODE_ENV=production
FRONTEND_URL=https://your-frontend.vercel.app

# Razorpay (LIVE keys)
RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxx
RAZORPAY_WEBHOOK_SECRET=xxxxxxxxxxxxxxxxxxxxxx

# Brevo Transactional Email API
BREVO_API_KEY=your-brevo-api-key

# Interakt WhatsApp API
INTERAKT_API_KEY=xxxxxxxxxxxxxxxxxxxxxx
INTERAKT_BASE_URL=https://api.interakt.ai/v1/public

# Google Sheets (Service Account JSON key path)
GOOGLE_SHEETS_CREDENTIALS=./credentials/google-service-account.json
GOOGLE_SHEET_ID=your-google-sheet-id-here

# Support
SUPPORT_EMAIL=support@arklearning.com
SUPPORT_PHONE=+91-XXXXXXXXXX

# Zapier Webhook (primary data log → Google Sheets)
ZAPIER_WEBHOOK_URL=https://hooks.zapier.com/hooks/catch/XXXXX/YYYYY/
